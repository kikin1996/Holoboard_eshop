
# --- Veřejné proměnné (smí jít do klienta, NEXT_PUBLIC_ prefix) ---
NEXT_PUBLIC_PACKETA_API_KEY=your-packeta-widget-api-key

# --- Backend / e-commerce jádro ---
MEDUSA_BACKEND_URL=https://your-medusa-instance.example.com
MEDUSA_ADMIN_TOKEN=replace-with-secret-admin-token
# Pokud používáte Strapi místo Medusy:
# STRAPI_URL=https://your-strapi-instance.example.com
# STRAPI_API_TOKEN=replace-with-secret-token

# --- ComGate (nikdy neprefixovat NEXT_PUBLIC_, zůstává jen na serveru) ---
COMGATE_MERCHANT_ID=123456
COMGATE_SECRET=replace-with-secret
COMGATE_TEST_MODE=true

# --- Revalidace obsahu (webhook z Medusy/Strapi po změně produktu) ---
REVALIDATE_SECRET=replace-with-random-string

# --- Veřejná URL nasazeného frontendu (pro redirect/cancel URL u ComGate) ---
NEXT_PUBLIC_SITE_URL=https://holoboard.vercel.app
